{
  "name": "ai-assited-coding",
  "version": "1.0.0",
  "description": "REST API with JWT authentication and SQLite database",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "testMatch": ["**/__tests__/**/*.test.js", "**/*.test.js"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JahidulSany/ai-assited-coding.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JahidulSany/ai-assited-coding/issues"
  },
  "homepage": "https://github.com/JahidulSany/ai-assited-coding#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
